*.coveragexml

# Publish output
publish/
out/

# Runtime & logs
*.log
*.tmp

# Environment / secrets
appsettings.Development.json
appsettings.Local.json
.env
*.pfx
*.p12

# macOS
.DS_Store

# Rider / JetBrains
*.DotSettings.user
